#!/usr/bin/env sh

set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT_PATH="$REPO_ROOT/scripts/generate-chat-context.ps1"

if [ ! -f "$SCRIPT_PATH" ]; then
  echo "[post-commit] Script tidak ditemukan: $SCRIPT_PATH"
  exit 0
fi

if command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT_PATH" -OutputFile "$REPO_ROOT/CHAT_CONTEXT_AUTO.md" >/dev/null 2>&1 || true
  exit 0
fi

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File "$SCRIPT_PATH" -OutputFile "$REPO_ROOT/CHAT_CONTEXT_AUTO.md" >/dev/null 2>&1 || true
  exit 0
fi

echo "[post-commit] powershell/pwsh tidak ditemukan, skip auto context generation"
exit 0
